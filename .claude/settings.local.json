      "Bash(~/.local/bin/json '{\"a\":1}')",
      "Bash(xxd)",
      "Bash(~/.local/bin/json '{\"name\":\"中文测试\",\"tags\":[\"a\",\"b\"]}')",
      "Bash(~/.local/bin/json '{\"a\":1, /* hi */ \"b\":[1,2,], }')",
