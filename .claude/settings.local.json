      "Bash(~/.local/bin/ssh-alias list *)",
      "Bash(./install.sh --uninstall json)",
      "Bash(chmod +x tools/json/colorize.py)",
      "Bash(~/.local/bin/json '{\"name\":\"中文\",\"n\":42,\"ok\":true,\"x\":null,\"arr\":[1,\"a\"]}')",
      "Bash(python3 tools/json/prettify.py)",
      "Bash(python3 tools/json/colorize.py)",
      "Bash(./install.sh --lang en json)",
      "Bash(./install.sh --lang fr json)"
