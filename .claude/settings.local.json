      "Bash(~/.local/bin/json 'not json at all')",
      "Bash(LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 bash ~/.local/bin/json '{\"a\":1}')",
      "Bash(chmod +x tools/json/prettify.py tools/json/json.sh)",
